  "homepage": "https://commit.show",
  "repository": {
    "type": "git",
    "url":  "https://github.com/commitshow/cli",
    "directory": "mcp"
  },
  "bugs": {
    "url": "https://github.com/commitshow/cli/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "typescript":  "^5.9.3"
  }
