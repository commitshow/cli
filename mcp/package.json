{
  "name": "commitshow-mcp",
  "version": "0.1.0",
  "description": "MCP server for commit.show — let Claude Desktop / Cursor / Cline / Windsurf audit any public GitHub repo through the Model Context Protocol.",
  "type": "module",
  "bin": {
    "commitshow-mcp": "./bin/commitshow-mcp.js"
  },
  "files": [
