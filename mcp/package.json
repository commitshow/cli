  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-desktop",
    "cursor",
    "windsurf",
    "cline",
    "commit.show",
    "audit",
    "vibe-coding",
    "code-quality"
  ],
